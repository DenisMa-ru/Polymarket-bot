POLYMARKET_PRIVATE_KEY=your_private_key_here
CAPITAL_USD=100
DRY_RUN=true # true for testing, false for real trading

# STRATEGIES CONFIG false as default
ARBITRAGE_ENABLED=false
DIPARB_ENABLED=false
SMARTMONEY_ENABLED=true
TREND_ANALYSIS_ENABLED=false

# ==============================================
# 📱 TELEGRAM NOTIFICATIONS (NEW in v3.2)
# ==============================================

# Enable Telegram notifications
TELEGRAM_ENABLED=false

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Your Chat ID from @userinfobot
TELEGRAM_CHAT_ID=123456789

# Notification types (true/false)
TG_NOTIFY_TRADE=true
TG_NOTIFY_TP=true
TG_NOTIFY_SL=true
TG_NOTIFY_TS=true
TG_NOTIFY_ARB=true
TG_NOTIFY_ERROR=true
TG_NOTIFY_WARN=true
TG_NOTIFY_DAILY=true
TG_NOTIFY_RISK=true
TG_NOTIFY_START=true
TG_NOTIFY_STOP=true

# Rate limiting
TG_MAX_MSG_PER_HOUR=50

# Silent hours (start_hour,end_hour) - leave empty to disable
TG_SILENT_HOURS=23,8
